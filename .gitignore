#-------------------------
# Operating Specific Junk Files
#-------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*~

#-------------------------
# Environment / Secrets
#-------------------------
.env
env.local

#-------------------------
# Dependencies
#-------------------------
/vendor/

#-------------------------
# Writable runtime data
#-------------------------
/writable/cache/*
!/writable/cache/index.html

/writable/logs/*
!/writable/logs/index.html

/writable/session/*
!/writable/session/index.html

/writable/uploads/*
!/writable/uploads/index.html

/writable/debugbar/*
!/writable/debugbar/index.html

php_errors.log

#-------------------------
# Tests / reports
#-------------------------
/tests/coverage*
/phpunit
/results/
/phpunit*.xml

#-------------------------
# IDE / local tooling
#-------------------------
.idea/
.vscode/
*.iml
.php-version
.phpintel

#-------------------------
# Build / misc
#-------------------------
/build/
/dist/
/api/
